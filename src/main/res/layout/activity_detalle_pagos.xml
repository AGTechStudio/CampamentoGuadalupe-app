<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#E6F2E6"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pagos del Alumno"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"/>

    <TextView
        android:id="@+id/txtCostoCampamento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Costo Campamento: $0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#444444"
        android:padding="4dp"/>

    <TextView
        android:id="@+id/txtResumen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pagado: $0 | Pendiente: $0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#444444"
        android:padding="4dp"/>

    <ListView
        android:id="@+id/listViewPagos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <Button
            android:id="@+id/btnAgregarPago"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Agregar Pago"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Volver"
            android:backgroundTint="#FFA726"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>




